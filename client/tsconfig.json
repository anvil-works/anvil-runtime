{
    "extends": "./tsconfig.base.json",
    "composite": true,
    "compilerOptions": {
        "paths": {
            "@Sk": ["./js/@Sk"],
            "PyDefUtils": ["./js/PyDefUtils"],
            "@runtime/*": ["./js/*"],
            "@runtime-assets/*": ["./*"]
        },
        "jsx": "preserve",
        "jsxFactory": "PyDefUtils.h",
        "types": ["google.maps", "jquery", "plotly.js", "youtube"]
    },
    "include": ["./"],
    "exclude": [
        "node_modules",
        "dist",
        "js/runner/components-in-js/packages"
    ]
}
