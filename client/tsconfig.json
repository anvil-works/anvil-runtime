{
    "extends": "./tsconfig.base.json",
    "composite": true,
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@Sk": ["./js/@Sk"],
            "PyDefUtils": ["js/PyDefUtils"],
            "@runtime/*": ["./js/*"],
            "@runtime-assets/*": ["./*"]
        },
        "jsx": "preserve",
        "jsxFactory": "PyDefUtils.h"
    },
    "include": ["./"],
    "exclude": ["node_modules", "js/runner/components-in-js/packages"]
}
